---
import AppShell from "../components/AppShell.astro";
import Card from "../components/Card.astro";
import TextInput from "../components/TextInput.astro";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Inicio | Generador de eBooks IA">
  <AppShell active="inicio">
    <section class="start-grid">
      <Card class="start-panel">
        <p class="eyebrow">Nuevo proyecto</p>
        <h2>Generador de eBooks</h2>
        <p class="muted">Ingresa un tema, configura la estructura y genera un eBook exportable.</p>
        <form class="start-form" id="start-form" novalidate>
          <TextInput
            id="topic-start"
            label="Tema del eBook"
            placeholder="Ejemplo: Marketing digital para principiantes"
            maxlength="160"
            required={true}
          />
          <div id="topic-error" class="error-box is-hidden"></div>
          <button class="button button-primary" type="submit">Comenzar</button>
        </form>
      </Card>
      <Card>
        <p class="eyebrow">Accesos</p>
        <h2>Continuar trabajo</h2>
        <p class="muted">Revisa ebooks generados anteriormente o confirma el estado de conexión del backend.</p>
        <div class="quick-links">
          <a class="button button-secondary" href="/ebooks">Mis eBooks</a>
          <a class="button button-secondary" href="/settings">Configuración</a>
        </div>
      </Card>
    </section>
  </AppShell>
</MainLayout>

<script>
  import { validateTopic } from "../scripts/validators";

  const form = document.querySelector<HTMLFormElement>("#start-form");
  const input = document.querySelector<HTMLInputElement>("#topic-start");
  const errorBox = document.querySelector<HTMLElement>("#topic-error");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    const topic = input?.value ?? "";
    const validation = validateTopic(topic);
    if (!validation.ok) {
      if (errorBox) {
        errorBox.textContent = validation.message ?? "Revisa el tema.";
        errorBox.classList.remove("is-hidden");
      }
      return;
    }
    sessionStorage.setItem("ebookTopic", topic.trim());
    window.location.href = "/create";
  });
</script>

